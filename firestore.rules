// ══════════════════════════════════════════════════════
// MELTED EGYPT — Firestore Security Rules
// Paste these in Firebase Console → Firestore → Rules
// ══════════════════════════════════════════════════════
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper: check if logged-in user is admin
    function isAdmin() {
      return request.auth != null &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isAdmin == true;
    }

    // Helper: only the stock field changes, must already be a number set by admin,
    // and the new value is strictly lower (decrement only, never increase, never below 0).
    function stockDecrementOnly() {
      let affected = request.resource.data.diff(resource.data).affectedKeys();
      return affected.hasOnly(['stock'])
        && resource.data.stock is int
        && request.resource.data.stock is int
        && request.resource.data.stock >= 0
        && request.resource.data.stock < resource.data.stock;
    }

    // Helper: only the usedBy array may change, and only by appending exactly
    // one element (the customer's email). No other field can be touched.
    function promoMarkUsedOnly() {
      let affected = request.resource.data.diff(resource.data).affectedKeys();
      let oldSize  = resource.data.get('usedBy', []).size();
      return affected.hasOnly(['usedBy'])
        && request.resource.data.usedBy is list
        && request.resource.data.usedBy.size() == oldSize + 1;
    }

    // USERS — only read/write own data, admin can read all
    match /users/{userId} {
      allow read:   if request.auth.uid == userId || isAdmin();
      allow create: if request.auth.uid == userId;
      allow update: if request.auth.uid == userId &&
        // Block users from setting isAdmin themselves
        !request.resource.data.diff(resource.data).affectedKeys().hasAny(['isAdmin']);
    }

    // PRODUCTS — anyone can read, only admin can write
    // Exception: anyone may decrement the stock field as part of placing an order.
    // stockDecrementOnly() ensures no other field can change, stock cannot increase,
    // cannot go below 0, and the admin must have already set a numeric stock value.
    match /products/{productId} {
      allow read:           if true;
      allow create, delete: if isAdmin();
      allow update:         if isAdmin() || stockDecrementOnly();
    }

    // OFFERS — anyone can read (used on public pages), only admin can write
    match /offers/{offerId} {
      allow read:  if true;
      allow write: if isAdmin();
    }

    // ORDERS — anyone can create (guest checkout), users see own, admin sees all
    match /orders/{orderId} {
      allow create: if true;
      allow read:   if request.auth != null && (resource.data.userId == request.auth.uid || isAdmin());
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // SETTINGS — anyone can read (transfer numbers shown at checkout), only admin writes
    match /settings/{doc} {
      allow read:  if true;
      allow write: if isAdmin();
    }

    // PROMO CODES — anyone can read (needed for client-side validation) and mark used
    // (the actual redemption write). Creating/editing/deleting is admin-only.
    // promoMarkUsedOnly() ensures only the 'used' flag can flip false→true, nothing else.
    match /promoCodes/{codeId} {
      allow read:   if true;
      allow create: if isAdmin();
      allow delete: if isAdmin();
      allow update: if isAdmin() || promoMarkUsedOnly();
    }

    // FLAVORS — anyone can read (shown on product cards), only admin writes
    match /flavors/{flavorId} {
      allow read:  if true;
      allow write: if isAdmin();
    }

    // EXTRAS — anyone can read (picked at add-to-cart, re-priced at checkout),
    // only admin writes
    match /extras/{extraId} {
      allow read:  if true;
      allow write: if isAdmin();
    }
  }
}
