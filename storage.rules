// ══════════════════════════════════════════════════════
// MELTED EGYPT — Firebase Storage Security Rules
// Paste these in Firebase Console → Storage → Rules
// ══════════════════════════════════════════════════════
rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // ── PAYMENT / TRANSFER PROOFS ─────────────────────────────────────────
    // Customers (including unauthenticated guests) may upload their proof
    // image. Enforced server-side: images only, max 5 MB.
    // Read is restricted to authenticated users (admins view via the console).
    // Note: download URLs generated by getDownloadURL() carry an unguessable
    // token and are served directly — these read rules protect SDK access only.
    match /deposits/{orderId} {
      allow write: if request.resource.contentType.matches('image/.*')
                   && request.resource.size < 5 * 1024 * 1024;
      allow read:  if request.auth != null;
    }

    // ── PRODUCT IMAGES ────────────────────────────────────────────────────
    // Public read so product images display on the storefront.
    // Write requires authentication; only admins reach this UI in practice,
    // and Firestore rules prevent non-admins from attaching URLs to products.
    match /products/{fileName} {
      allow read:  if true;
      allow write: if request.auth != null;
    }

    // ── OFFER IMAGES ──────────────────────────────────────────────────────
    match /offers/{fileName} {
      allow read:  if true;
      allow write: if request.auth != null;
    }

    // Default: deny everything not matched above
  }
}
