// ══════════════════════════════════════════════════════
// MELTED EGYPT — Firebase Storage Security Rules
// Paste these in Firebase Console → Storage → Rules
// ══════════════════════════════════════════════════════
rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // ── PAYMENT / TRANSFER PROOFS ─────────────────────────────────────────
    // Path: deposits/{orderId}/{fileName}
    // Customers (including unauthenticated guests) may UPLOAD their proof image.
    // Enforced server-side: images only, max 5 MB.
    // READ is restricted to signed-in users — only the admin panel reads these
    // (the customer stores the path on the order and never reads it back). Storage
    // rules cannot query Firestore, so a true isAdmin() check isn't possible here;
    // request.auth != null is admin-only in practice since only admins reach that UI.
    match /deposits/{orderId}/{fileName} {
      allow write: if request.resource.contentType.matches('image/.*')
                   && request.resource.size < 5 * 1024 * 1024;
      allow read:  if request.auth != null;
    }

    // ── PRODUCT IMAGES ────────────────────────────────────────────────────
    // Public read so product images display on the storefront.
    // Write requires authentication; only admins reach this UI in practice,
    // and Firestore rules prevent non-admins from attaching URLs to products.
    match /products/{fileName} {
      allow read:  if true;
      allow write: if request.auth != null;
    }

    // ── OFFER IMAGES ──────────────────────────────────────────────────────
    match /offers/{fileName} {
      allow read:  if true;
      allow write: if request.auth != null;
    }

    // Default: deny everything not matched above
  }
}
